<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SuzerainSaveEditor"
             x:Class="SuzerainSaveEditor.BaseGamePage"
             x:DataType="local:BaseGameViewModel"
             Title="Base Game">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Base Game Editor" Style="{StaticResource Headline}" HorizontalOptions="Center" />
            
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Load Save File" Command="{Binding LoadSaveFileCommand}" />
                <Button Text="Refresh" Command="{Binding RefreshDataCommand}" />
                <Button Text="Save Changes" Command="{Binding SaveSaveFileCommand}" />
                <Button Text="Export As..." Command="{Binding ExportSaveFileCommand}" />
            </HorizontalStackLayout>
            <Label Text="{Binding StatusText}" HorizontalOptions="Center" FontAttributes="Bold" TextColor="Green" />

            <!-- Core & Opinion -->
            <Border Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Core &amp; Opinion" FontAttributes="Bold" FontSize="18"/>
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" Text="Budget" />
                        <Entry Grid.Row="1" Grid.Column="0" Keyboard="Numeric" Text="{Binding GovernmentBudget}" TextColor="{Binding BudgetTextColor}" />
                        
                        <Label Grid.Row="0" Grid.Column="1" Text="Wealth" />
                        <Entry Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Text="{Binding PersonalWealth}" />
                        
                        <Label Grid.Row="0" Grid.Column="2" Text="Unrest" />
                        <Entry Grid.Row="1" Grid.Column="2" Keyboard="Numeric" Text="{Binding CountryUnrest}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Public Opinion" />
                        <Entry Grid.Row="3" Grid.Column="0" Keyboard="Numeric" Text="{Binding PublicOpinion}" />
                        
                        <Label Grid.Row="2" Grid.Column="1" Text="Bludish Opinion" />
                        <Entry Grid.Row="3" Grid.Column="1" Keyboard="Numeric" Text="{Binding BludishOpinion}" />
                        
                        <Label Grid.Row="2" Grid.Column="2" Text="Scandals (0=none)" />
                        <Entry Grid.Row="3" Grid.Column="2" Keyboard="Numeric" Text="{Binding LeakedScandalsSeverity}" />
                    </Grid>
                    <Label Text="{Binding BudgetWarningText}" TextColor="Red" FontAttributes="Bold" IsVisible="{Binding BudgetWarningText, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Politics & Reform -->
            <Border Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Politics &amp; Reform" FontAttributes="Bold" FontSize="18"/>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" Text="Assembly Vote" />
                        <Entry Grid.Row="1" Grid.Column="0" Keyboard="Numeric" Text="{Binding ReformAssemblyVote}" />
                        
                        <Label Grid.Row="0" Grid.Column="1" Text="Court Vote" />
                        <Entry Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Text="{Binding ReformCourtVote}" />
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" Text="Albin Convinced" VerticalOptions="Center"/>
                        <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding AlbinConvinced}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Gloria Convinced" VerticalOptions="Center"/>
                        <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding GloriaConvinced}" />
                        
                        <Label Grid.Row="2" Grid.Column="0" Text="T4 Albin Convinced" VerticalOptions="Center"/>
                        <Switch Grid.Row="2" Grid.Column="1" IsToggled="{Binding Turn04AConvinceAlbin}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="T4 Gloria Convinced" VerticalOptions="Center"/>
                        <Switch Grid.Row="3" Grid.Column="1" IsToggled="{Binding Turn04AConvinceGloria}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
            
            <!-- Economy -->
            <Border Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Economy &amp; Trade (Set to 15 to recover)" FontAttributes="Bold" FontSize="18"/>
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" Text="Agnland" />
                        <Entry Grid.Row="1" Grid.Column="0" Keyboard="Numeric" Text="{Binding EconomyAgnland}" />
                        
                        <Label Grid.Row="0" Grid.Column="1" Text="Bergia" />
                        <Entry Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Text="{Binding EconomyBergia}" />
                        
                        <Label Grid.Row="0" Grid.Column="2" Text="Lorren" />
                        <Entry Grid.Row="1" Grid.Column="2" Keyboard="Numeric" Text="{Binding EconomyLorren}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Gruni" />
                        <Entry Grid.Row="3" Grid.Column="0" Keyboard="Numeric" Text="{Binding EconomyGruni}" />
                        
                        <Label Grid.Row="2" Grid.Column="1" Text="Trade Amount" />
                        <Entry Grid.Row="3" Grid.Column="1" Keyboard="Numeric" Text="{Binding TradeAmount}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Military -->
            <Border Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Military" FontAttributes="Bold" FontSize="18"/>
                    <Label Text="NOTE: Toggling both Expansion and Modernization for the same branch is not recommended due to unknown effects." FontSize="12" TextColor="DarkGoldenrod"/>
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <!-- Expansion -->
                        <Label Grid.Row="0" Grid.Column="0" Text="Expand Army" VerticalOptions="Center"/>
                        <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding Turn06SnOExpansionArmy}" />
                        <Switch Grid.Row="0" Grid.Column="2" IsToggled="{Binding SituationMilitaryExpandedArmy}" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Expand Navy" VerticalOptions="Center"/>
                        <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding Turn06SnOExpansionNavy}" />
                        <Switch Grid.Row="1" Grid.Column="2" IsToggled="{Binding SituationMilitaryExpandedNavy}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Expand Air" VerticalOptions="Center"/>
                        <Switch Grid.Row="2" Grid.Column="1" IsToggled="{Binding Turn06SnOExpansionAirforce}" />
                        <Switch Grid.Row="2" Grid.Column="2" IsToggled="{Binding SituationMilitaryExpandedAirForce}" />
                    </Grid>
                     <BoxView HeightRequest="1" Color="Gray" Margin="0,5"/>
                     <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <!-- Modernization -->
                        <Label Grid.Row="0" Grid.Column="0" Text="Modernize Army" VerticalOptions="Center"/>
                        <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding Turn06SnOModernisationArmy}" />
                        <Switch Grid.Row="0" Grid.Column="2" IsToggled="{Binding SituationMilitaryModernisedArmy}" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Modernize Navy" VerticalOptions="Center"/>
                        <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding Turn06SnOModernisationNavy}" />
                        <Switch Grid.Row="1" Grid.Column="2" IsToggled="{Binding SituationMilitaryModernisedNavy}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Modernize Air" VerticalOptions="Center"/>
                        <Switch Grid.Row="2" Grid.Column="1" IsToggled="{Binding Turn06SnOModernisationAirforce}" />
                        <Switch Grid.Row="2" Grid.Column="2" IsToggled="{Binding SituationMilitaryModernisedAirForce}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>